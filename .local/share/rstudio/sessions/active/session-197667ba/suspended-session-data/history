library(RSQLite)
library(tidyverse)
#connect to the database with the dbConnect function
#this database is stored in a folder on the server
con <- dbConnect(SQLite(), "../../shared/mtsthelens.db")
dbListTables(con)
#connect to your data tables
#don’t actually load the data into memory yet
plot_data <- tbl(con, "plot_data")
plot_info <- tbl(con, "plot_info")
#information in a data table
dbListFields(con, "plot_data")
# Now use dplyr verbs - they'll be translated to SQL
eightyone <- plot_data %>%
filter(year == 1981) %>%
collect()  # execute and return to R
# Look at the ABPL years grouped and mean richness each year at that plot :p
db_filtered_ABPL <- plot_data %>%
filter(plot_name == "ABPL") %>%
group_by(year) %>%
summarize(mean(richness)) %>%
collect()
db_filtered_ABPL
plot(db_filtered_ABPL,
main = "ABPL Richness Plot",
col = "black")
db_filtered_BUCA <- plot_data %>%
filter(plot_name == "BUCA") %>%
group_by(year) %>%
summarize(mean(richness)) %>%
collect()
db_filtered_BUCA
plot(db_filtered_BUCA,
main = "BUCA Richness Plot",
col = "red")
db_filtered_BUCB <- plot_data %>%
filter(plot_name == "BUCB") %>%
group_by(year) %>%
summarize(mean(richness)) %>%
collect()
db_filtered_BUCB
plot(db_filtered_BUCB,
main = "BUCB Richness Plot",
col = "red")
